{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usesecure.dev/schemas/secure-json-v1.schema.json",
  "title": "Secure Engine secure-json-v1 document",
  "oneOf": [
    { "$ref": "#/$defs/scanReport" },
    { "$ref": "#/$defs/doctorReport" }
  ],
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "relativeGlob": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[\\\\\\u0000-\\u001F\\u007F]).+$"
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "span": {
      "type": "object",
      "required": ["start_byte", "end_byte", "start_line", "start_column", "end_line", "end_column"],
      "properties": {
        "start_byte": { "type": "integer", "minimum": 0 },
        "end_byte": { "type": "integer", "minimum": 0 },
        "start_line": { "type": "integer", "minimum": 1 },
        "start_column": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "end_column": { "type": "integer", "minimum": 1 }
      }
    },
    "location": {
      "type": "object",
      "required": ["path", "span"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "configuration": {
      "type": "object",
      "required": ["include_hidden", "max_files", "max_file_bytes", "respect_ignore_files"],
      "properties": {
        "include_hidden": { "type": "boolean" },
        "max_files": { "type": "integer", "minimum": 1, "maximum": 10000000 },
        "max_file_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "respect_ignore_files": { "type": "boolean" },
        "include_patterns": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/relativeGlob" }
        },
        "exclude_patterns": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/relativeGlob" }
        },
        "include_generated": { "type": "boolean" },
        "include_vendor": { "type": "boolean" },
        "include_nested_repositories": { "type": "boolean" },
        "max_total_bytes": { "type": "integer", "minimum": 1, "maximum": 17592186044416 },
        "max_depth": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 1024 },
            { "type": "null" }
          ]
        },
        "max_errors": { "type": "integer", "minimum": 1, "maximum": 1000 }
      }
    },
    "repository": {
      "type": "object",
      "required": ["name", "vcs", "revision", "content_fingerprint", "identity_fingerprint"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "pattern": "^[^/\\\\]+$" },
        "vcs": { "type": ["string", "null"] },
        "revision": {
          "oneOf": [
            { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" },
            { "type": "null" }
          ]
        },
        "repository_kind": {
          "enum": ["directory", "git-repository", "git-worktree"]
        },
        "content_fingerprint": { "$ref": "#/$defs/fingerprint" },
        "identity_fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "scanMetadata": {
      "type": "object",
      "required": ["started_at", "finished_at", "duration_ms", "complete", "files_discovered", "files_scanned"],
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "complete": { "const": true },
        "files_discovered": { "type": "integer", "minimum": 0 },
        "files_scanned": { "type": "integer", "minimum": 0 }
      }
    },
    "file": {
      "type": "object",
      "required": ["path", "kind", "size_bytes", "content_fingerprint", "language"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "kind": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "content_fingerprint": { "$ref": "#/$defs/fingerprint" },
        "language": { "type": ["string", "null"] },
        "origin": { "enum": ["project", "generated", "vendor"] },
        "is_binary": { "type": "boolean" }
      }
    },
    "inventory": {
      "type": "object",
      "required": ["entries_seen", "candidate_files", "files_selected", "files_scanned", "text_files", "binary_files", "generated_files", "vendor_files", "bytes_scanned", "symlinks_skipped", "nested_repositories_skipped", "hit_file_limit", "hit_total_byte_limit"],
      "properties": {
        "entries_seen": { "type": "integer", "minimum": 0 },
        "candidate_files": { "type": "integer", "minimum": 0 },
        "files_selected": { "type": "integer", "minimum": 0 },
        "files_scanned": { "type": "integer", "minimum": 0 },
        "text_files": { "type": "integer", "minimum": 0 },
        "binary_files": { "type": "integer", "minimum": 0 },
        "generated_files": { "type": "integer", "minimum": 0 },
        "vendor_files": { "type": "integer", "minimum": 0 },
        "bytes_scanned": { "type": "integer", "minimum": 0 },
        "symlinks_skipped": { "type": "integer", "minimum": 0 },
        "nested_repositories_skipped": { "type": "integer", "minimum": 0 },
        "hit_file_limit": { "type": "boolean" },
        "hit_total_byte_limit": { "type": "boolean" }
      }
    },
    "language": {
      "type": "object",
      "required": ["name", "file_count", "bytes"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "file_count": { "type": "integer", "minimum": 1 },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "manifest": {
      "type": "object",
      "required": ["kind", "location", "fingerprint"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "framework": {
      "type": "object",
      "required": ["name", "evidence", "fingerprint"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "evidence": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "entryPoint": {
      "type": "object",
      "required": ["kind", "location", "fingerprint"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "capability": {
      "type": "object",
      "required": ["capability", "reason", "evidence", "fingerprint"],
      "properties": {
        "capability": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "evidence": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "trustBoundary": {
      "type": "object",
      "required": ["kind", "description", "evidence", "fingerprint"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "evidence": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "finding": {
      "type": "object",
      "required": ["rule_id", "finding_id", "title", "category", "severity", "confidence", "evidence", "invariant", "prerequisites", "impact", "remediation", "verification_state", "limitations", "fingerprint"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "finding_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/location" } },
        "invariant": { "type": "string", "minLength": 1 },
        "prerequisites": { "type": "array", "items": { "type": "string" } },
        "impact": { "type": "string", "minLength": 1 },
        "remediation": { "type": "string", "minLength": 1 },
        "verification_state": { "type": "string", "minLength": 1 },
        "limitations": { "type": "array", "items": { "type": "string" } },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "limitation": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "skippedFile": {
      "type": "object",
      "required": ["path", "reason"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "exclusion": {
      "type": "object",
      "required": ["reason", "count"],
      "properties": {
        "reason": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 1 }
      }
    },
    "boundedError": {
      "type": "object",
      "required": ["code", "path", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "path": { "oneOf": [{ "$ref": "#/$defs/relativePath" }, { "type": "null" }] },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "scanReport": {
      "type": "object",
      "required": ["schema_version", "engine_version", "document_type", "repository", "configuration", "scan", "files", "languages", "manifests", "frameworks", "entry_points", "capabilities", "trust_boundaries", "findings", "limitations", "skipped_files", "errors", "report_fingerprint"],
      "properties": {
        "schema_version": { "const": "secure-json-v1" },
        "engine_version": { "type": "string", "minLength": 1 },
        "document_type": { "const": "scan-report" },
        "repository": { "$ref": "#/$defs/repository" },
        "configuration": { "$ref": "#/$defs/configuration" },
        "scan": { "$ref": "#/$defs/scanMetadata" },
        "inventory": { "$ref": "#/$defs/inventory" },
        "files": { "type": "array", "items": { "$ref": "#/$defs/file" } },
        "languages": { "type": "array", "items": { "$ref": "#/$defs/language" } },
        "manifests": { "type": "array", "items": { "$ref": "#/$defs/manifest" } },
        "frameworks": { "type": "array", "items": { "$ref": "#/$defs/framework" } },
        "entry_points": { "type": "array", "items": { "$ref": "#/$defs/entryPoint" } },
        "capabilities": { "type": "array", "items": { "$ref": "#/$defs/capability" } },
        "trust_boundaries": { "type": "array", "items": { "$ref": "#/$defs/trustBoundary" } },
        "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
        "limitations": { "type": "array", "items": { "$ref": "#/$defs/limitation" } },
        "skipped_files": { "type": "array", "items": { "$ref": "#/$defs/skippedFile" } },
        "exclusions": { "type": "array", "items": { "$ref": "#/$defs/exclusion" } },
        "errors": { "type": "array", "maxItems": 1000, "items": { "$ref": "#/$defs/boundedError" } },
        "report_fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "doctorCheck": {
      "type": "object",
      "required": ["name", "status", "detail"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "warn", "fail"] },
        "detail": { "type": "string", "minLength": 1 }
      }
    },
    "doctorReport": {
      "type": "object",
      "required": ["schema_version", "engine_version", "document_type", "healthy", "checks"],
      "properties": {
        "schema_version": { "const": "secure-json-v1" },
        "engine_version": { "type": "string", "minLength": 1 },
        "document_type": { "const": "doctor-report" },
        "healthy": { "type": "boolean" },
        "checks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/doctorCheck" } }
      }
    }
  }
}
