{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usesecure.dev/schemas/secure-json-v1.schema.json",
  "title": "Secure Engine secure-json-v1 document",
  "oneOf": [
    { "$ref": "#/$defs/scanReport" },
    { "$ref": "#/$defs/doctorReport" }
  ],
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "relativeGlob": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[\\\\\\u0000-\\u001F\\u007F]).+$"
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "taxonomyCoordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taxonomy_version", "category_id", "invariant_id"],
      "properties": {
        "taxonomy_version": { "const": "1.0.0" },
        "category_id": { "type": "string", "pattern": "^secure-bench\\.category\\.[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "invariant_id": { "type": "string", "pattern": "^secure-bench\\.invariant\\.[a-z0-9]+(?:-[a-z0-9]+)*$" }
      }
    },
    "cweReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url"],
      "properties": {
        "id": { "type": "string", "pattern": "^CWE-[1-9][0-9]*$" },
        "url": { "type": "string", "pattern": "^https://cwe\\.mitre\\.org/data/definitions/[1-9][0-9]*\\.html$" }
      }
    },
    "ruleTaxonomyProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taxonomy_name", "source_commit", "content_hash", "mapping_basis"],
      "properties": {
        "taxonomy_name": { "const": "secure-bench-taxonomy-v1" },
        "source_commit": { "const": "93c0821db065de436a339c15b070e158947ad76c" },
        "content_hash": { "const": "22852bd7401020b315af11dfa2b60c0b46f78eb19f95079e6400d7b3bea3272c" },
        "mapping_basis": { "const": "secure-engine-built-in-rule-family" }
      }
    },
    "taxonomyDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taxonomy_name", "taxonomy_version", "source_version", "source_commit", "schema_sha256", "taxonomy_sha256", "methodology_sha256", "content_hash"],
      "properties": {
        "taxonomy_name": { "const": "secure-bench-taxonomy-v1" },
        "taxonomy_version": { "const": "1.0.0" },
        "source_version": { "const": "CWE 4.20" },
        "source_commit": { "const": "93c0821db065de436a339c15b070e158947ad76c" },
        "schema_sha256": { "const": "cdecd643d338aa8ae42ec7398c6c4703cb97d60ad355340c98744fc94bcb7d6f" },
        "taxonomy_sha256": { "const": "059fe22d7707cf8d17f2c1621fdae9819787a1958ba2ef0421eca4e4ec858452" },
        "methodology_sha256": { "const": "eac27e5800be35c5ae77f7804e52ae90462cbda403a5484baa8fab62f02ab562" },
        "content_hash": { "const": "22852bd7401020b315af11dfa2b60c0b46f78eb19f95079e6400d7b3bea3272c" }
      }
    },
    "span": {
      "type": "object",
      "required": ["start_byte", "end_byte", "start_line", "start_column", "end_line", "end_column"],
      "properties": {
        "start_byte": { "type": "integer", "minimum": 0 },
        "end_byte": { "type": "integer", "minimum": 0 },
        "start_line": { "type": "integer", "minimum": 1 },
        "start_column": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "end_column": { "type": "integer", "minimum": 1 }
      }
    },
    "location": {
      "type": "object",
      "required": ["path", "span"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "configuration": {
      "type": "object",
      "required": ["include_hidden", "max_files", "max_file_bytes", "respect_ignore_files"],
      "properties": {
        "include_hidden": { "type": "boolean" },
        "max_files": { "type": "integer", "minimum": 1, "maximum": 10000000 },
        "max_file_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "respect_ignore_files": { "type": "boolean" },
        "include_patterns": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/relativeGlob" }
        },
        "exclude_patterns": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/relativeGlob" }
        },
        "include_generated": { "type": "boolean" },
        "include_vendor": { "type": "boolean" },
        "include_nested_repositories": { "type": "boolean" },
        "max_total_bytes": { "type": "integer", "minimum": 1, "maximum": 17592186044416 },
        "max_depth": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 1024 },
            { "type": "null" }
          ]
        },
        "max_errors": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "parse_cache_enabled": { "type": "boolean" },
        "max_cache_bytes": { "type": "integer", "minimum": 1, "maximum": 17179869184 },
        "max_parser_diagnostics": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "max_facts_per_file": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "max_total_facts": { "type": "integer", "minimum": 1, "maximum": 10000000 },
        "max_graph_nodes": { "type": "integer", "minimum": 1, "maximum": 10000000 },
        "max_graph_edges": { "type": "integer", "minimum": 1, "maximum": 20000000 },
        "max_interprocedural_depth": { "type": "integer", "minimum": 1, "maximum": 32 },
        "max_findings": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "suppressions": {
          "type": "array",
          "maxItems": 10000,
          "items": { "$ref": "#/$defs/suppression" }
        }
      }
    },
    "suppression": {
      "type": "object",
      "required": ["rule_id", "path", "start_byte", "reason"],
      "properties": {
        "rule_id": { "type": "string", "pattern": "^SE[0-9]{4}$" },
        "path": { "$ref": "#/$defs/relativePath" },
        "start_byte": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "repository": {
      "type": "object",
      "required": ["name", "vcs", "revision", "content_fingerprint", "identity_fingerprint"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "pattern": "^[^/\\\\]+$" },
        "vcs": { "type": ["string", "null"] },
        "revision": {
          "oneOf": [
            { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" },
            { "type": "null" }
          ]
        },
        "repository_kind": {
          "enum": ["directory", "git-repository", "git-worktree"]
        },
        "content_fingerprint": { "$ref": "#/$defs/fingerprint" },
        "identity_fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "scanMetadata": {
      "type": "object",
      "required": ["started_at", "finished_at", "duration_ms", "complete", "files_discovered", "files_scanned"],
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "complete": { "const": true },
        "files_discovered": { "type": "integer", "minimum": 0 },
        "files_scanned": { "type": "integer", "minimum": 0 }
      }
    },
    "file": {
      "type": "object",
      "required": ["path", "kind", "size_bytes", "content_fingerprint", "language"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "kind": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "content_fingerprint": { "$ref": "#/$defs/fingerprint" },
        "language": { "type": ["string", "null"] },
        "origin": { "enum": ["project", "generated", "vendor"] },
        "is_binary": { "type": "boolean" }
      }
    },
    "inventory": {
      "type": "object",
      "required": ["entries_seen", "candidate_files", "files_selected", "files_scanned", "text_files", "binary_files", "generated_files", "vendor_files", "bytes_scanned", "symlinks_skipped", "nested_repositories_skipped", "hit_file_limit", "hit_total_byte_limit"],
      "properties": {
        "entries_seen": { "type": "integer", "minimum": 0 },
        "candidate_files": { "type": "integer", "minimum": 0 },
        "files_selected": { "type": "integer", "minimum": 0 },
        "files_scanned": { "type": "integer", "minimum": 0 },
        "text_files": { "type": "integer", "minimum": 0 },
        "binary_files": { "type": "integer", "minimum": 0 },
        "generated_files": { "type": "integer", "minimum": 0 },
        "vendor_files": { "type": "integer", "minimum": 0 },
        "bytes_scanned": { "type": "integer", "minimum": 0 },
        "symlinks_skipped": { "type": "integer", "minimum": 0 },
        "nested_repositories_skipped": { "type": "integer", "minimum": 0 },
        "hit_file_limit": { "type": "boolean" },
        "hit_total_byte_limit": { "type": "boolean" }
      }
    },
    "parsing": {
      "type": "object",
      "required": ["files_eligible", "files_parsed", "files_with_diagnostics", "facts_extracted", "duration_ms", "cache_enabled", "cache_hits", "cache_misses", "cache_writes", "cache_entries_ignored"],
      "properties": {
        "files_eligible": { "type": "integer", "minimum": 0 },
        "files_parsed": { "type": "integer", "minimum": 0 },
        "files_with_diagnostics": { "type": "integer", "minimum": 0 },
        "facts_extracted": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "cache_enabled": { "type": "boolean" },
        "cache_hits": { "type": "integer", "minimum": 0 },
        "cache_misses": { "type": "integer", "minimum": 0 },
        "cache_writes": { "type": "integer", "minimum": 0 },
        "cache_entries_ignored": { "type": "integer", "minimum": 0 }
      }
    },
    "parserProvenance": {
      "type": "object",
      "required": ["parser", "parser_version", "grammar", "extractor_version"],
      "properties": {
        "parser": { "type": "string", "minLength": 1 },
        "parser_version": { "type": "string", "minLength": 1 },
        "grammar": { "type": "string", "minLength": 1 },
        "extractor_version": { "type": "string", "minLength": 1 }
      }
    },
    "factRelationship": {
      "type": "object",
      "required": ["kind", "target"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "normalizedFact": {
      "type": "object",
      "required": ["fact_id", "kind", "location", "name", "relationships", "provenance", "fingerprint"],
      "properties": {
        "fact_id": { "type": "string", "pattern": "^sf_[0-9a-f]{24}$" },
        "kind": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/location" },
        "name": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 512 },
            { "type": "null" }
          ]
        },
        "relationships": { "type": "array", "items": { "$ref": "#/$defs/factRelationship" } },
        "provenance": { "$ref": "#/$defs/parserProvenance" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "parserDiagnostic": {
      "type": "object",
      "required": ["diagnostic_id", "code", "message", "location", "recoverable", "provenance"],
      "properties": {
        "diagnostic_id": { "type": "string", "pattern": "^pd_[0-9a-f]{24}$" },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/location" },
        "recoverable": { "type": "boolean" },
        "provenance": { "$ref": "#/$defs/parserProvenance" }
      }
    },
    "parserCoverage": {
      "type": "object",
      "required": ["parser_mode", "files_eligible", "files_parsed", "files_with_diagnostics", "facts_extracted"],
      "properties": {
        "parser_mode": { "enum": ["javascript", "jsx", "typescript", "tsx", "rust", "python", "go"] },
        "files_eligible": { "type": "integer", "minimum": 0 },
        "files_parsed": { "type": "integer", "minimum": 0 },
        "files_with_diagnostics": { "type": "integer", "minimum": 0 },
        "facts_extracted": { "type": "integer", "minimum": 0 }
      }
    },
    "language": {
      "type": "object",
      "required": ["name", "file_count", "bytes"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "file_count": { "type": "integer", "minimum": 1 },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "manifest": {
      "type": "object",
      "required": ["kind", "location", "fingerprint"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "framework": {
      "type": "object",
      "required": ["name", "evidence", "fingerprint"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "evidence": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "entryPoint": {
      "type": "object",
      "required": ["kind", "location", "fingerprint"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "capability": {
      "type": "object",
      "required": ["capability", "reason", "evidence", "fingerprint"],
      "properties": {
        "capability": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "evidence": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "trustBoundary": {
      "type": "object",
      "required": ["kind", "description", "evidence", "fingerprint"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "evidence": { "$ref": "#/$defs/location" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "finding": {
      "type": "object",
      "required": ["rule_id", "finding_id", "title", "category", "severity", "confidence", "evidence", "invariant", "prerequisites", "impact", "remediation", "verification_state", "limitations", "fingerprint"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "finding_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/location" } },
        "source": { "oneOf": [{ "$ref": "#/$defs/location" }, { "type": "null" }] },
        "transformations": { "type": "array", "items": { "$ref": "#/$defs/location" } },
        "guards": { "type": "array", "items": { "$ref": "#/$defs/location" } },
        "sink": { "oneOf": [{ "$ref": "#/$defs/location" }, { "type": "null" }] },
        "evidence_path": { "type": "array", "items": { "$ref": "#/$defs/evidencePathStep" } },
        "invariant": { "type": "string", "minLength": 1 },
        "taxonomy": { "$ref": "#/$defs/taxonomyCoordinates" },
        "primary_cwe": { "$ref": "#/$defs/cweReference" },
        "taxonomy_provenance": { "$ref": "#/$defs/ruleTaxonomyProvenance" },
        "prerequisites": { "type": "array", "items": { "type": "string" } },
        "impact": { "type": "string", "minLength": 1 },
        "remediation": { "type": "string", "minLength": 1 },
        "verification_state": { "type": "string", "minLength": 1 },
        "limitations": { "type": "array", "items": { "type": "string" } },
        "fingerprint": { "$ref": "#/$defs/fingerprint" },
        "semantic_fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "evidenceSemantic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "identity", "certainty"],
      "properties": {
        "role": { "enum": ["untrusted-source", "transformation", "guard", "sanitizer", "authorization-check", "sensitive-sink"] },
        "identity": { "type": "string", "pattern": "^(untrusted|transformation|guard|sanitizer|sink)\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
        "policy": { "type": "string", "minLength": 1 },
        "authorization": { "enum": ["authentication", "role", "ownership", "tenant", "general"] },
        "certainty": { "enum": ["proven", "uncertain"] }
      }
    },
    "evidenceNode": {
      "type": "object",
      "required": ["node_id", "kind", "name", "location", "provenance", "fingerprint"],
      "properties": {
        "node_id": { "type": "string", "pattern": "^gn_[0-9a-f]{24}$" },
        "kind": { "type": "string", "minLength": 1 },
        "name": { "oneOf": [{ "type": "string", "minLength": 1, "maxLength": 512 }, { "type": "null" }] },
        "semantic": { "$ref": "#/$defs/evidenceSemantic" },
        "location": { "$ref": "#/$defs/location" },
        "provenance": { "$ref": "#/$defs/parserProvenance" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "evidenceEdge": {
      "type": "object",
      "required": ["edge_id", "kind", "from_node", "to_node", "location", "provenance", "fingerprint"],
      "properties": {
        "edge_id": { "type": "string", "pattern": "^ge_[0-9a-f]{24}$" },
        "kind": { "type": "string", "minLength": 1 },
        "from_node": { "type": "string", "pattern": "^gn_[0-9a-f]{24}$" },
        "to_node": { "type": "string", "pattern": "^gn_[0-9a-f]{24}$" },
        "location": { "$ref": "#/$defs/location" },
        "provenance": { "$ref": "#/$defs/parserProvenance" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "evidenceGraph": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": { "type": "array", "maxItems": 10000000, "items": { "$ref": "#/$defs/evidenceNode" } },
        "edges": { "type": "array", "maxItems": 20000000, "items": { "$ref": "#/$defs/evidenceEdge" } }
      }
    },
    "evidencePathStep": {
      "type": "object",
      "required": ["node_id", "edge_id_from_previous", "kind", "location", "provenance", "fingerprint"],
      "properties": {
        "node_id": { "type": "string", "pattern": "^gn_[0-9a-f]{24}$" },
        "edge_id_from_previous": { "oneOf": [{ "type": "string", "pattern": "^ge_[0-9a-f]{24}$" }, { "type": "null" }] },
        "kind": { "type": "string", "minLength": 1 },
        "semantic": { "$ref": "#/$defs/evidenceSemantic" },
        "location": { "$ref": "#/$defs/location" },
        "provenance": { "$ref": "#/$defs/parserProvenance" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "analysis": {
      "type": "object",
      "required": ["nodes", "edges", "candidate_paths", "rules_evaluated", "findings", "findings_suppressed", "duration_ms", "truncated"],
      "properties": {
        "nodes": { "type": "integer", "minimum": 0 },
        "edges": { "type": "integer", "minimum": 0 },
        "candidate_paths": { "type": "integer", "minimum": 0 },
        "rules_evaluated": { "type": "integer", "minimum": 0 },
        "findings": { "type": "integer", "minimum": 0 },
        "findings_suppressed": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "truncated": { "type": "boolean" }
      }
    },
    "suppressionDiagnostic": {
      "type": "object",
      "required": ["suppression_id", "code", "rule_id", "path", "message"],
      "properties": {
        "suppression_id": { "type": "string", "pattern": "^sd_[0-9a-f]{24}$" },
        "code": { "enum": ["applied", "invalid-rule", "invalid-scope", "invalid-reason", "stale"] },
        "rule_id": { "type": "string", "minLength": 1 },
        "path": { "oneOf": [{ "$ref": "#/$defs/relativePath" }, { "type": "null" }] },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "limitation": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "skippedFile": {
      "type": "object",
      "required": ["path", "reason"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "exclusion": {
      "type": "object",
      "required": ["reason", "count"],
      "properties": {
        "reason": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 1 }
      }
    },
    "boundedError": {
      "type": "object",
      "required": ["code", "path", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "path": { "oneOf": [{ "$ref": "#/$defs/relativePath" }, { "type": "null" }] },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "scanReport": {
      "type": "object",
      "required": ["schema_version", "engine_version", "document_type", "repository", "configuration", "scan", "files", "languages", "manifests", "frameworks", "entry_points", "capabilities", "trust_boundaries", "findings", "limitations", "skipped_files", "errors", "report_fingerprint"],
      "properties": {
        "schema_version": { "const": "secure-json-v1" },
        "engine_version": { "type": "string", "minLength": 1 },
        "document_type": { "const": "scan-report" },
        "repository": { "$ref": "#/$defs/repository" },
        "configuration": { "$ref": "#/$defs/configuration" },
        "scan": { "$ref": "#/$defs/scanMetadata" },
        "inventory": { "$ref": "#/$defs/inventory" },
        "parsing": { "$ref": "#/$defs/parsing" },
        "facts": { "type": "array", "items": { "$ref": "#/$defs/normalizedFact" } },
        "parser_diagnostics": { "type": "array", "maxItems": 100000, "items": { "$ref": "#/$defs/parserDiagnostic" } },
        "parser_coverage": { "type": "array", "items": { "$ref": "#/$defs/parserCoverage" } },
        "graph": { "$ref": "#/$defs/evidenceGraph" },
        "analysis": { "$ref": "#/$defs/analysis" },
        "suppression_diagnostics": { "type": "array", "items": { "$ref": "#/$defs/suppressionDiagnostic" } },
        "taxonomy_catalog": { "type": "array", "maxItems": 16, "items": { "$ref": "#/$defs/taxonomyDescriptor" } },
        "files": { "type": "array", "items": { "$ref": "#/$defs/file" } },
        "languages": { "type": "array", "items": { "$ref": "#/$defs/language" } },
        "manifests": { "type": "array", "items": { "$ref": "#/$defs/manifest" } },
        "frameworks": { "type": "array", "items": { "$ref": "#/$defs/framework" } },
        "entry_points": { "type": "array", "items": { "$ref": "#/$defs/entryPoint" } },
        "capabilities": { "type": "array", "items": { "$ref": "#/$defs/capability" } },
        "trust_boundaries": { "type": "array", "items": { "$ref": "#/$defs/trustBoundary" } },
        "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
        "limitations": { "type": "array", "items": { "$ref": "#/$defs/limitation" } },
        "skipped_files": { "type": "array", "items": { "$ref": "#/$defs/skippedFile" } },
        "exclusions": { "type": "array", "items": { "$ref": "#/$defs/exclusion" } },
        "errors": { "type": "array", "maxItems": 1000, "items": { "$ref": "#/$defs/boundedError" } },
        "report_fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "doctorCheck": {
      "type": "object",
      "required": ["name", "status", "detail"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "warn", "fail"] },
        "detail": { "type": "string", "minLength": 1 }
      }
    },
    "doctorReport": {
      "type": "object",
      "required": ["schema_version", "engine_version", "document_type", "healthy", "checks"],
      "properties": {
        "schema_version": { "const": "secure-json-v1" },
        "engine_version": { "type": "string", "minLength": 1 },
        "document_type": { "const": "doctor-report" },
        "healthy": { "type": "boolean" },
        "checks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/doctorCheck" } }
      }
    }
  }
}
